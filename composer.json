{
    "name": "shimosyan/php-uploader",
    "description": "Simple PHP file uploader with download/delete authentication",
    "version": "2.0.2",
    "type": "project",
    "keywords": [
        "php",
        "uploader",
        "file-sharing"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "shimosyan"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-sqlite3": "*",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PHPUploader\\Core\\": "src/Core/",
            "PHPUploader\\Model\\": "app/models/"
        },
        "classmap": [
            "app/models/"
        ]
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "check-syntax": "find . -name '*.php' -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit",
        "test:integration": "phpunit --configuration phpunit.xml.dist --testsuite Integration",
        "release": "php scripts/release.php"
    }
}
